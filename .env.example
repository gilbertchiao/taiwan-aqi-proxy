# ==========================================================
# taiwan-aqi-proxy 環境變數範例
# 複製本檔為 .env 後填入實際值: cp .env.example .env
# 真實環境變數的優先權高於 .env (方便容器化部署覆寫)
# ==========================================================

# === 環境部開放資料平台 (必填) ===
# 申請網址: https://data.moenv.gov.tw/ (註冊會員後於會員中心取得 API Key)
MOENV_API_KEY=your-moenv-api-key-here

# 資料集代碼:空氣品質指標 (AQI)。一般無須更動。
MOENV_DATASET=aqx_p_432

# API 基底網址 (v2 介面)。一般無須更動。
MOENV_BASE_URL=https://data.moenv.gov.tw/api/v2

# === 目標測站 ===
# 測站編號 SiteId;可用逗號分隔多站,例如 67,1,5。
# 三重測站為 67。測站對照: https://data.moenv.gov.tw/dataset/detail/AQX_P_07
# API 查詢即以此編號為路徑參數,例如 GET /api/v1/aqi/67
SITE_ID=67

# === 排程設定 ===
# 是否啟用 API 進程內建的排程器。
#   true  = 同進程排程 (單一容器即可,免額外 cron)
#   false = 改用外部 Cron 觸發 `aqi-proxy fetch`
ENABLE_SCHEDULER=true

# 每小時第幾分鐘執行 (0-59)。建議 10,確保撈到官方最新整點資料。
SCHEDULE_MINUTE=10

# === 重試 / 逾時 ===
# 上游失敗時最大重試次數。
MAX_RETRIES=3
# 每次重試間隔秒數 (PRD 建議 180 秒 = 3 分鐘)。
RETRY_DELAY_SECONDS=180
# HTTP 請求逾時秒數。
HTTP_TIMEOUT_SECONDS=30

# === 資料過期判斷 ===
# 最新資料距今超過此時數即標記 is_stale=true。
STALE_THRESHOLD_HOURS=2

# === 儲存 ===
# SQLite 資料庫檔案路徑 (相對於工作目錄或使用絕對路徑)。
DATABASE_PATH=data/aqi.db

# === 日誌 ===
# 日誌等級: DEBUG / INFO / WARN / ERROR
LOG_LEVEL=INFO
# 日誌輸出目錄 (每日輪替、舊檔自動壓縮、保留 30 天)。
LOG_DIR=logs

# === API 服務 ===
API_HOST=0.0.0.0
API_PORT=8000

# 手動觸發更新端點 (POST /api/v1/refresh) 的權杖。
# 留空則停用該端點 (回 404),建議正式環境設定一組隨機字串。
REFRESH_TOKEN=
